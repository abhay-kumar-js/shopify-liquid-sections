<section class="a-blog-section">
  <style>
    .a-blog-section {
      padding: 60px 20px;
      background: #f5f6f7;
    }

    .a-container {
      max-width: 1400px;
      margin: auto;
    }

    /* FEATURED BLOG */
    .a-featured {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 40px;
      align-items: center;
      margin-bottom: 40px;
    }

    .a-img {
      width: 100%;
      border-radius: 14px;
      overflow: hidden;
    }

    .a-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: 0.4s;
    }

    .a-img:hover img {
      transform: scale(1.05);
    }

    .a-content {
      margin-top: 10px;
    }

    .a-meta {
      font-size: 12px;
      color: #6b6b6b;
      margin-bottom: 8px;
    }

    .a-title {
      font-size: 28px;
      line-height: 1.3;
      margin: 0 0 12px;
    }

    .a-title a {
      text-decoration: none;
      color: #111;
    }

    .a-title a:hover {
      text-decoration: underline;
    }

    .a-desc {
      font-size: 14px;
      color: #555;
      line-height: 1.6;
    }

    /* BLOG GRID */
    .a-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 25px;
    }

    .a-card {
      text-decoration: none;
      color: #111;
      display: block;
    }

    .a-card .a-title {
      font-size: 20px;
    }

    /* RESPONSIVE */
    @media (max-width: 900px) {
      .a-featured {
        grid-template-columns: 1fr;
      }

      .a-grid {
        grid-template-columns: 1fr;
      }

      .a-title {
        font-size: 22px;
      }
    }
  </style>

  <div class="a-container">
    {% assign selected_blog = blogs[section.settings.blog] %}

    {% if selected_blog != blank %}
      {% assign featured = selected_blog.articles.first %}

      <!-- FEATURED ARTICLE -->

      <div class="a-featured">
        <div class="a-img">
          <img
            width=""
            height=""
            src="{{ featured.image | image_url: width:900 }}"
            alt="{{ featured.title }}"
          >
        </div>

        <div class="a-content">
          <div class="a-meta">
            {{ featured.created_at | date: '%b %d, %Y' }}
          </div>

          <h2 class="a-title">
            <a href="{{ featured.url }}">
              {{ featured.title }}
            </a>
          </h2>

          <p class="a-desc">
            {{ featured.excerpt | strip_html | truncate: 120 }}
          </p>
        </div>
      </div>

      <!-- GRID ARTICLES -->

      <div class="a-grid">
        {% for article in selected_blog.articles offset: 1 limit: 3 %}
          <a href="{{ article.url }}" class="a-card">
            <div class="a-img">
              <img
                width=""
                height=""
                src="{{ article.image | image_url: width:600 }}"
                alt="{{ article.title }}"
              >
            </div>

            <div class="a-content">
              <div class="a-meta">
                {{ article.created_at | date: '%b %d, %Y' }}
              </div>

              <h3 class="a-title">
                {{ article.title }}
              </h3>

              <p class="a-desc">
                {{ article.excerpt | strip_html | truncate: 80 }}
              </p>
            </div>
          </a>
        {% endfor %}
      </div>

    {% else %}
      <p>No blog selected</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "A Blog Cards",
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "Select Blog"
    }
  ],
  "presets": [
    {
      "name": "A Blog Cards"
    }
  ]
}
{% endschema %}
