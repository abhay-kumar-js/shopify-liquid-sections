{% liquid
  assign background = section.settings.background
  assign container_class = section.settings.layout

  assign container_full = false
  if container_class == 'container-fluid'
    assign container_full = true
  endif

  assign heading = section.settings.heading
  assign heading_font_family = section.settings.heading_font_family
  assign heading_font_size = section.settings.heading_font_size
  assign heading_font_size_tablet = section.settings.heading_font_size_tablet
  assign heading_font_size_mobile = section.settings.heading_font_size_mobile
  assign heading_font_weight = section.settings.heading_font_weight
  assign heading_letter_spacing = section.settings.heading_letter_spacing
  assign heading_text_transform = section.settings.heading_text_transform
  assign heading_space_bottom = section.settings.heading_space_bottom
  assign heading_space_bottom_tablet = section.settings.heading_space_bottom_tablet
  assign heading_space_bottom_mobile = section.settings.heading_space_bottom_mobile

  assign image_ratio = section.settings.image_ratio
  assign product_content_alignment = section.settings.product_title_alignment

  assign viewall_label = section.settings.view_button_label
  assign viewall_url = section.settings.view_button_link

  assign slider_autoplay = section.settings.slider_autoplay
  assign slider_autoplay_delay = section.settings.slider_autoplay_delay | times: 1000
  assign slide_per_view_desktop = section.settings.slide_per_view_desktop
  assign slide_per_view_tablet = section.settings.slide_per_view_tablet
  assign slide_per_view_mobile = section.settings.slide_per_view_mobile
  assign slider_space_between = section.settings.slider_space_between

  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom

  assign mobile_padding_top = section.settings.mobile_padding_top
  assign mobile_padding_bottom = section.settings.mobile_padding_bottom
%}
{% style %}
  .product-slider-wrapper .section-head{
      display: flex;
      align-items: end;
      gap: 30px;
      justify-content: space-between;
      flex-wrap: wrap;
  }
  .product-slider-wrapper .section-head .title{
      margin-bottom: 0;
      flex:1;
  }
  .product-slider-{{ section.id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    background-color: {{ background }};
    --product-card-alignment : {{ product_content_alignment }};
  }
  .product-slider-{{ section.id }} .section-head{
    margin-bottom: {{ heading_space_bottom }}px;
  }
  .product-slider-{{ section.id }} .title{
    display: block;
    font-family: {{ heading_font_family }};
    font-size: {{ heading_font_size }}px;
    font-weight: {{ heading_font_weight }};
    text-transform: {{ heading_text_transform }};
    letter-spacing: {{ heading_letter_spacing }}px;
  }
  @media only screen and (max-width: 991px) {
    .product-slider-{{ section.id }} .title{
      font-size: {{ heading_font_size_tablet }}px;
    }
    .product-slider-{{ section.id }} .section-head{
      margin-bottom: {{ heading_space_bottom_tablet }}px;
    }
  }
  @media only screen and (max-width: 768px) {
    .product-slider-{{ section.id }}{
      padding-top: {{ mobile_padding_top }}px;
      padding-bottom: {{ mobile_padding_bottom }}px;
    }
  }
  @media only screen and (max-width: 575px) {
    .product-slider-{{ section.id }} .title{
      font-size: {{ heading_font_size_mobile }}px;
    }
    .product-slider-{{ section.id }} .section-head{
      margin-bottom: {{ heading_space_bottom_mobile }}px;
    }
    .product-slider-wrapper .section-head .title{
        flex: unset;
    }
    .product-slider-wrapper .section-head{
        gap: 10px;
    }
  }
{% endstyle %}

<div class="product-slider-wrapper {{ background }} product-slider-{{ section.id }}">
  <div class="{{ container_class }}">
    {%- if heading != blank or viewall_label != blank -%}
      <div
        class="section-head"
      >
        {%- if heading != blank -%}
          <h2 class="title">{{ heading }}</h2>
        {%- endif -%}
        {%- if viewall_label != blank -%}
          <a
            class="view-all-btn"
            {%- if viewall_url == blank -%}
              role="link" aria-disabled="true"
            {%- else -%}
              href="{{ viewall_url }}"
            {%- endif -%}
          >
            <span>{{ viewall_label }}</span>
            <svg viewBox="0 0 13 20">
              <polyline points="0.5 19.5 3 19.5 12.5 10 3 0.5" />
            </svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
    <div class="swiper swiper-items-equal product-swiper-{{ section.id }}">
      <div class="swiper-wrapper">
        {% if section.settings.collection.products == blank %}
          {%- for product in (1..section.settings.product_limit) -%}
            {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
            {%- assign placeholder_image = 'product-' | append: placeholder_image_index -%}

            <div class="swiper-slide">
              {% render 'card-product-no-info', placeholder_image: placeholder_image %}
            </div>
          {% endfor %}
        {% else %}
          {% for product in section.settings.collection.products limit: section.settings.product_limit %}
            {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
            {%- assign placeholder_image = 'product-' | append: placeholder_image_index -%}
            <div class="swiper-slide">
              {% render 'card-product',
                product: product,
                media_aspect_ratio: image_ratio,
                container_full: container_full,
                serial: forloop.index,
                placeholder_image: placeholder_image
              %}
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var swiper = new Swiper('.product-swiper-{{ section.id }}', {
      slidesPerView: {{ slide_per_view_mobile }},
      spaceBetween: {{ slider_space_between }},
      speed: 500,
      {% if slider_autoplay %}
      autoplay: {
        delay: {{ slider_autoplay_delay }}
      },
      {% endif %}
      breakpoints: {
        1200: {
          slidesPerView: {{ slide_per_view_desktop }},
          spaceBetween: {{ slider_space_between }},
        },
        768: {
          slidesPerView: {{ slide_per_view_tablet }},
          spaceBetween: {{ slider_space_between }},
        },
        300: {
          slidesPerView: {{ slide_per_view_mobile }},
          spaceBetween: 10,
        },
      },
    });
  });
</script>

