<section class="custom-collection">
  <div class="page-width">
    <!-- HEADER -->
    <div class="section-header">
      {% if section.settings.heading != blank %}
        <h2 class="section-title">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.enable_slider and section.settings.layout == 'slider' %}
        <div class="nav-wrapper">
          <button class="nav prev"><span>&#8249;</span></button>
          <button class="nav next"><span>&#8250;</span></button>
        </div>
      {% endif %}
    </div>

    <!-- COLLECTION -->
    {% assign selected_collection = section.settings.collection %}

    <div class="collection-slider">
      <div class="collection-track {% if section.settings.layout == 'grid' %}grid-layout{% else %}slider-layout{% endif %}">
        {% if selected_collection != blank and selected_collection.products_count > 0 %}
          {% for product in selected_collection.products limit: section.settings.products_to_show %}
            <div class="product-card">
              <!-- BADGE -->
              {% if section.settings.show_badges %}
                {% if product.tags contains 'top' %}
                  <span class="badge">Top Seller 🔥</span>
                {% elsif product.tags contains 'fav' %}
                  <span class="badge">All-Time Fav ❤️</span>
                {% endif %}
              {% endif %}

              <!-- MEDIA -->
              <div class="media-wrapper">
                {% if product.media.size > 0 %}
                  {% for media in product.media %}
                    <img
                      width=""
                      height=""
                      src="{{ media | image_url: width: 600 }}"
                      class="product-image {% if forloop.first %}active{% endif %}"
                      data-index="{{ forloop.index0 }}"
                      loading="lazy"
                    >
                  {% endfor %}
                {% else %}
                  <img
                    width=""
                    height=""
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    class="product-image active"
                  >
                {% endif %}

                <!-- DOTS -->
                {% if product.media.size > 1 %}
                  <div class="dots">
                    {% for media in product.media %}
                      <span
                        class="dot {% if forloop.first %}active{% endif %}"
                        data-index="{{ forloop.index0 }}"
                      ></span>
                    {% endfor %}
                  </div>
                {% endif %}
              </div>

              <!-- INFO -->
              <div class="product-info">
                <h3>{{ product.title }}</h3>
                <p>{{ product.price | money }}</p>
              </div>
            </div>
          {% endfor %}

        {% else %}
          <p style="padding:20px;">No products found. Please select a collection.</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .custom-collection {
    padding: 40px 0;
  }

  /* HEADER */
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
  }

  .section-title {
    font-size: 28px;
    font-weight: 600;
  }

  /* NAV */
  .nav-wrapper {
    display: flex;
    gap: 10px;
  }

  .nav {
    position: relative;
    border: 1px solid #000;
    background: transparent;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    cursor: pointer;
    overflow: hidden;
  }

  .nav::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #000;
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav:hover::before {
    transform: scaleY(1);
  }

  .nav span {
    position: relative;
    z-index: 2;
    color: #000;
    transition: color 0.25s ease;
  }

  .nav:hover span {
    color: #fff;
  }

  /* ===== LAYOUTS ===== */

  /* SLIDER */
  .collection-track.slider-layout {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-behavior: smooth;
  }

  /* GRID */
  .collection-track.grid-layout {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  /* PRODUCT */
  .product-card {
    width: 100%;
    background: #f7f7f7;
    border-radius: 16px;
    padding: 12px;
    position: relative;
  }

  /* ONLY FOR SLIDER */
  .slider-layout .product-card {
    width: 315px;
    flex: 0 0 auto;
  }

  /* BADGE */
  .badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #000;
    color: #fff;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 12px;
    z-index: 2;
  }

  /* MEDIA */
  .media-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    aspect-ratio: 1 / 1;
    background: #eee;
  }

  .product-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: none;
  }

  .product-image.active {
    display: block;
  }

  /* DOTS */
  .dots {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    background: #fff;
    padding: 6px 10px;
    border-radius: 20px;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .media-wrapper:hover .dots {
    opacity: 1;
  }

  .dot {
    width: 6px;
    height: 6px;
    background: #bbb;
    border-radius: 50%;
    transition: all 0.25s ease;
  }

  .dot.active {
    background: #000;
    transform: scale(1.4);
  }

  /* INFO */
  .product-info {
    margin-top: 10px;
  }

  .product-info h3 {
    font-size: 16px;
  }

  .product-info p {
    font-size: 14px;
  }

  /* TABLET */
  @media (max-width: 1024px) {
    .collection-track.grid-layout {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* MOBILE → 2 PRODUCTS */
  @media (max-width: 600px) {
    .collection-track.grid-layout {
      grid-template-columns: repeat(2, 1fr);
    }
    .product-info {
      display: block;
      margin: 0 !important;
    }
    .product-info h3 {
      font-size: 14px;
    }
    /* ONLY FOR SLIDER */
    .product-card {
      border-radius: 12px;
      padding: 6px;
    }
    .slider-layout .product-card {
      width: 192px !important;
    }
    /* SLIDER */
    .collection-track.slider-layout {
      gap: 10px;
    }
  }
</style>

<script>
  document.querySelectorAll('.custom-collection').forEach((section) => {
    const track = section.querySelector('.collection-track');

    /* SLIDER ONLY */
    if (track && track.classList.contains('slider-layout')) {
      const next = section.querySelector('.next');
      const prev = section.querySelector('.prev');

      if (next && prev) {
        next.onclick = () => track.scrollBy({ left: 320, behavior: 'smooth' });
        prev.onclick = () => track.scrollBy({ left: -320, behavior: 'smooth' });
      }
    }

    /* HOVER IMAGE */
    section.querySelectorAll('.media-wrapper').forEach((wrapper) => {
      const images = wrapper.querySelectorAll('.product-image');
      const dots = wrapper.querySelectorAll('.dot');
      const total = images.length;

      if (total <= 1) return;

      wrapper.addEventListener('mousemove', (e) => {
        const rect = wrapper.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const percent = x / rect.width;

        const index = Math.min(total - 1, Math.floor(percent * total));

        images.forEach((img) => img.classList.remove('active'));
        dots.forEach((dot) => dot.classList.remove('active'));

        if (images[index]) {
          images[index].classList.add('active');
          dots[index].classList.add('active');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Products Collection Algo",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "DISCOVER OUR BESTSELLERS"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout Type",
      "options": [
        { "value": "slider", "label": "Slider" },
        { "value": "grid", "label": "Grid" }
      ],
      "default": "slider"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Number of products",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "label": "Enable Slider Navigation",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "label": "Show Product Badges",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Products Collection Algo"
    }
  ]
}
{% endschema %}

