                  <span class="badge">All-Time Fav ❤️</span>
                {% endif %}
              {% endif %}

              <!-- MEDIA -->
              <div class="media-wrapper">
                <div class="image-slider">
                  {% assign media_limit = 0 %}
                  {% for media in product.media %}
                    {% if media_limit < 3 %}
                      <img
                        width=""
                        height=""
                        src="{{ media | image_url: width: 600 }}"
                        class="slide-image"
                        loading="lazy"
                      >
                      {% assign media_limit = media_limit | plus: 1 %}
                    {% endif %}
                  {% endfor %}
                </div>

                <!-- DOTS -->
                {% if product.media.size > 1 %}
                  <div class="dots">
                    {% for media in product.media limit: 3 %}
