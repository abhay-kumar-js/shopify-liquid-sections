                        data-index="{{ forloop.index0 }}"
                      ></span>
                    {% endfor %}
                  </div>
                {% endif %}
              </div>

              <!-- INFO -->
              <div class="product-info">
                <h3>{{ product.title }}</h3>
                <p>{{ product.price | money }}</p>
              </div>

              <!-- ADD TO CART (BOTTOM FIXED) -->
              {% if section.settings.show_add_to_cart %}
                <div class="cart-btn-wrapper">
                  <form method="post" action="/cart/add">
                    <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                    <button type="submit" class="add-to-cart-btn">Add to Cart</button>
                  </form>
                </div>
              {% endif %}
            </div>
          {% endfor %}
        {% else %}
          <p>No products found.</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .custom-collection {
    padding: 40px 0;
  }

  /* HEADER */
  .section-collection-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
  }
  .section-title {
    font-size: 28px;
    font-weight: 600;
  }

  /* NAV */
  .nav-wrapper {
    display: flex;
    gap: 10px;
  }
  .nav {
    position: relative;
    border: 1px solid #000;
    background: transparent;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    cursor: pointer;
    overflow: hidden;
  }
  .nav::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #000;
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .nav:hover::before {
    transform: scaleY(1);
  }
  .nav span {
    position: relative;
    z-index: 2;
  }
  .nav:hover span {
    color: #fff;
  }

  /* LAYOUT */
  .collection-track.slider-layout {
    display: flex;
    gap: 20px;
    overflow-x: auto;
  }
  .collection-track.grid-layout {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  /* CARD FIXED SIZE */
  .product-card {
    width: 315px;
    height: 400px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: #f7f7f7;
    border-radius: 16px;
    padding: 12px;
    position: relative;
    flex: 0 0 auto;
  }

  /* MEDIA */
  .media-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    aspect-ratio: 1/1;
    cursor: col-resize;
  }

  /* SLIDER */
  .image-slider {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 0.4s ease;
  }
  .slide-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    flex: 0 0 100%;
  }

  /* DOTS */
  .dots {
    position: absolute;
    bottom: -4px;
