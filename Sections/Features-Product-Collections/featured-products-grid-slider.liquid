<section
  class="ap-featured-products"
  id="ap-featured-{{ section.id }}"
  data-mobile-layout="{{ section.settings.mobile_layout }}"
>
  <div class="ap-container">
    <div class="ap-header">
      <h2 class="ap-heading">{{ section.settings.heading }}</h2>

      <div class="ap-header-right">
        {% if section.settings.enable_slider and section.settings.show_nav_buttons %}
          <div class="ap-nav">
            <button class="ap-prev">‹</button>
            <button class="ap-next">›</button>
          </div>
        {% endif %}

        {% if section.settings.view_all_link != blank %}
          <a class="ap-view-all" href="{{ section.settings.view_all_link }}">
            {{ section.settings.view_all_text }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="ap-products {% if section.settings.enable_slider %}ap-slider{% else %}ap-grid{% endif %}">
      {% for product in collections[section.settings.collection].products limit: section.settings.products_to_show %}
        <div class="ap-card">
          <a href="{{ product.url }}" class="ap-card-media">
            <div class="ap-image-wrapper ratio-{{ section.settings.image_ratio }}">
              {% assign first = product.featured_media.preview_image %}
              {% assign second = product.images[1] %}

              <img src="{{ first | image_url: width: 800 }}" class="ap-img-main" loading="lazy">

              {% if section.settings.enable_second_image and second != blank %}
                <img src="{{ second | image_url: width: 800 }}" class="ap-img-hover" loading="lazy">
              {% endif %}

              {% if product.tags contains 'new' %}
                <span class="ap-badge">NEW</span>
              {% elsif product.tags contains 'best-seller' %}
                <span class="ap-badge">BEST SELLER</span>
              {% endif %}
            </div>
          </a>

          <div class="ap-card-info">
            <h3 class="ap-title">
              <a href="{{ product.url }}">
                {{ product.title | truncate: 20 }}
              </a>
            </h3>

            {% if product.tags contains 'men' %}
              <div class="ap-category">Men</div>
            {% elsif product.tags contains 'women' %}
              <div class="ap-category">Women</div>
            {% elsif product.tags contains 'unisex' %}
              <div class="ap-category">Unisex</div>
            {% endif %}

            {% if product.metafields.custom.product_info != blank %}
              <div class="ap-info">
                {{ product.metafields.custom.product_info }}
              </div>
            {% endif %}

            {% if product.metafields.reviews.rating.value != blank %}
              <div class="ap-rating">
                {% assign rating = product.metafields.reviews.rating.value | floor %}
                {% for i in (1..5) %}
                  {% if i <= rating %}★{% else %}☆{% endif %}
                {% endfor %}
                <span class="ap-review-count"> ({{ product.metafields.reviews.rating_count }}) </span>
              </div>
            {% endif %}

            <div class="ap-price">
              {% if product.compare_at_price > product.price %}
                <span class="ap-sale-price">
                  {{ product.price | money }}
                </span>

                <span class="ap-compare-price">
                  {{ product.compare_at_price | money }}
                </span>

              {% else %}
                <span class="ap-regular-price">
                  {{ product.price | money }}
                </span>
              {% endif %}
            </div>

            <button
              class="ap-btn ap-add-to-cart"
              data-variant-id="{{ product.first_available_variant.id }}"
            >
              <span>ADD TO BAG</span>
            </button>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #ap-featured-{{ section.id }}{
    padding: {{ section.settings.section_padding }}px;
  }

  .ap-container{
    max-width:1400px;
    margin:auto;
  }

  .ap-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:20px;
  }

  .ap-header-right{
    display:flex;
    align-items:center;
    gap:16px;
  }

  .ap-heading{
    font-size: {{ section.settings.heading_size }}px;
    margin:0;
  }

  .ap-view-all{
    text-decoration:underline;
    font-size:14px;
  }

  .ap-nav{
    display:flex;
    gap:6px;
  }

  .ap-nav button{
    width:32px;
    height:32px;
    border:1px solid #000;
    background:#fff;
    cursor:pointer;
    font-size:18px;
  }

  .ap-products{
    display:flex;
    gap: {{ section.settings.grid_gap }}px;
  }

  .ap-grid{
    flex-wrap:wrap;
  }

  .ap-grid .ap-card{
    width:calc(25% - {{ section.settings.grid_gap }}px);
  }

  .ap-slider{
    overflow:hidden;
  }

  .ap-slider .ap-card{
    flex:0 0 calc(25% - {{ section.settings.grid_gap }}px);
  }

  .ap-image-wrapper{
    position:relative;
    overflow:hidden;
  }

  .ap-image-wrapper img{
    width:100%;
    height:100%;
    object-fit:cover;
    display:block;
  }

  .ap-img-hover{
    position:absolute;
    top:0;
    left:0;
    opacity:0;
    transition:opacity .3s;
  }

  .ap-card:hover .ap-img-hover{
    opacity:1;
  }

  .ap-badge{
    position:absolute;
    top:10px;
    left:10px;
    background:#000;
    color:#fff;
    font-size:11px;
    padding:5px 8px;
  }

  .ratio-square{aspect-ratio:1/1;}
  .ratio-portrait{aspect-ratio:3/4;}
  .ratio-adapt img{height:auto;}

  .ap-card-info{
    margin-top:10px;
  }

  .ap-title{
    font-size: {{ section.settings.title_size }}px;
    margin:5px 0;
  }

  .ap-category{
    font-size:12px;
    opacity:.7;
  }

  .ap-info{
    font-size:12px;
    margin-bottom:4px;
  }

  .ap-rating{
    font-size:14px;
  }

  .ap-review-count{
    font-size:12px;
    margin-left:5px;
  }

  .ap-price{
    font-size: {{ section.settings.price_size }}px;
    margin-bottom:10px;
  }

  .ap-compare-price{
    text-decoration:line-through;
    opacity:.6;
    margin-left:6px;
  }

  .ap-btn{
    width:100%;
    border:1px solid #000;
    background:transparent;
    padding:10px;
    cursor:pointer;
    transition:none;
  }

  .ap-btn.loading{
    opacity:.6;
    pointer-events:none;
  }

  /* No hover effect */
  .ap-btn:hover{
    background:transparent;
    color:inherit;
    border-color:#000;
  }

  @media(max-width:768px){

    #ap-featured-{{ section.id }}{
      padding: {{ section.settings.section_padding_mobile }}px;
    }

    .ap-products{
      gap: {{ section.settings.grid_gap_mobile }}px;
    }

    .ap-heading{
      font-size: {{ section.settings.heading_size_mobile }}px;
    }

    .ap-title{
      font-size: {{ section.settings.title_size_mobile }}px;
    }

    .ap-price{
      font-size: {{ section.settings.price_size_mobile }}px;
    }

    .ap-grid .ap-card{
      width:48%;
    }

    #ap-featured-{{ section.id }}[data-mobile-layout="2_3"] .ap-slider .ap-card{
      flex:0 0 43%;
    }

    #ap-featured-{{ section.id }}[data-mobile-layout="1_2"] .ap-slider .ap-card{
      flex:0 0 83%;
    }

  }
</style>

<script>
  /* ======================
     SLIDER NAVIGATION
  ====================== */

  const slider = document.querySelector('#ap-featured-{{ section.id }} .ap-slider');

  if (slider) {

    const next = document.querySelector('#ap-featured-{{ section.id }} .ap-next');
    const prev = document.querySelector('#ap-featured-{{ section.id }} .ap-prev');

    const cardWidth = slider.querySelector('.ap-card').offsetWidth + {{ section.settings.grid_gap }};

    next?.addEventListener('click', () => {
      slider.scrollBy({ left: cardWidth, behavior: 'smooth' });
    });

    prev?.addEventListener('click', () => {
      slider.scrollBy({ left: -cardWidth, behavior: 'smooth' });
    });

  }


  /* ======================
     ADD TO BAG FIX
  ====================== */

  document.querySelectorAll('#ap-featured-{{ section.id }} .ap-add-to-cart')
  .forEach(button => {

  button.addEventListener('click', function(){

  const variantId = this.dataset.variantId;
  const cartDrawer = document.querySelector('cart-drawer');

  this.classList.add('loading');

  /* ADD PRODUCT */

  fetch('/cart/add.js', {
  method: 'POST',
  headers: {
  'Content-Type': 'application/json'
  },
  body: JSON.stringify({
  id: variantId,
  quantity: 1
  })
  })
  .then(() => {

  /* REQUEST UPDATED CART HTML */

  return fetch('/cart?sections=cart-drawer,cart-icon-bubble');

  })
  .then(res => res.json())
  .then(sections => {

  if(cartDrawer){

  cartDrawer.renderContents({
  sections: sections,
  id: variantId
  });

  }

  })
  .catch(error => {
  console.error('Cart error:', error);
  })
  .finally(() => {
  this.classList.remove('loading');
  });

  });

  });
</script>

