<section class="a-fragrance-section">
  <style>
    .a-fragrance-section {
      padding: 40px 16px;
    }

    .a-page-width {
      max-width: 1800px;
      margin: auto;
    }

    .a-section-title-container {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
      flex-wrap: wrap;
    }

    .a-section-title {
      font-size: 30px;
      font-weight: 400;
      margin: 0;
    }

    .a-section-title span {
      color: #f07d32;
    }

    .a-nav-button {
      position: relative;
      padding: 10px 22px;
      border: 1px solid #000;
      text-decoration: none;
      color: #000;
      font-size: 14px;
      overflow: hidden;
      z-index: 1;
    }

    .a-nav-button::before {
      content: '';
      position: absolute;
      left: 0;
      bottom: 0;
      width: 100%;
      height: 0%;
      background: #000;
      transition: height 0.35s ease;
      z-index: -1;
    }

    .a-nav-button:hover {
      color: #000;
    }

    .a-nav-button:hover::before {
      height: 100%;
    }

    .a-fragrance-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 25px;
    }

    .a-fragrance-card {
      background: #f7f7f7;
      border-radius: 16px;
      overflow: hidden;
      text-decoration: none;
      color: #000;
      display: block;
    }

    .a-product-media {
      width: 100%;
      aspect-ratio: 1/1;
      overflow: hidden;
    }

    .a-product-media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }

    .a-fragrance-card:hover .a-product-media img {
      transform: scale(1.1);
    }

    .a-product-info {
      padding: 12px 10px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .a-product-title {
      font-size: 20px;
      font-weight: 400;
      margin: 0;
      position: relative;
      display: inline-block;
      text-transform: uppercase;
    }

    .a-product-title::after {
      content: '';
      position: absolute;
      left: 0;
      bottom: -4px;
      width: 0%;
      height: 2px;
      background: ##f7f7f7;
      transition: width 0.35s ease;
    }

    .a-fragrance-card:hover .a-product-title::after {
      width: 100%;
    }

    .a-product-description {
      font-weight: 400;
      font-size: 14px;
      color: #000;
      text-transform: uppercase;
      margin-top: 5px;
    }

    .a-arrow {
      font-size: 20px;
      border: 1px solid #000;
      transform: rotate(45deg);
      transition: transform 0.35s ease;
      padding: 4px 10.5px;
      border-radius: 50%;
    }

    .a-fragrance-card:hover .a-arrow {
      transform: rotate(0deg);
    }

    .a-slider-mode {
      display: flex;
      overflow-x: auto;
      gap: 25px;
      scroll-snap-type: x mandatory;
    }

    .a-slider-mode .a-fragrance-card {
      flex: 0 0 auto;
      min-width: 260px;
      scroll-snap-align: start;
    }

    @media (max-width: 900px) {
      .a-fragrance-grid {
        grid-template-columns: 1fr 1fr;
      }

      .a-section-title {
        font-size: 28px;
      }
    }

    @media (max-width: 600px) {
      .a-fragrance-grid {
        grid-template-columns: 1fr 1fr;
        gap: 15px;
      }

      .a-product-info {
        padding: 8px 6px;
      }

      .a-section-title {
        font-size: 20px;
      }

      .a-product-title {
        font-size: 14px;
      }

      .a-product-description {
        font-size: 10px;
        margin: 0;
      }

      .a-arrow {
        font-size: 14px;
        padding: 3.2px 7.2px;
      }

      .a-nav-button {
        padding: 8px 22px;
      }
    }
  </style>

  <div class="a-page-width">
    <div class="a-section-title-container">
      <h2 class="a-section-title">
        {{ section.settings.heading }}
        <span>{{ section.settings.highlight }}</span>
      </h2>

      {% if section.settings.show_button %}
        <a href="{{ section.settings.button_link }}" class="a-nav-button">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>

    <div class="a-fragrance-grid" id="aCollectionGrid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="a-fragrance-card" {{ block.shopify_attributes }}>
          <div class="a-product-media">
            {% if block.settings.image != blank %}
              <img
                width=""
                height=""
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.title }}"
              >
            {% endif %}
          </div>

          <div class="a-product-info">
            <div>
              <h3 class="a-product-title">{{ block.settings.title }}</h3>
              <p class="a-product-description">{{ block.settings.description }}</p>
            </div>

            <div class="a-arrow">→</div>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>

  <script>
    const layout = '{{ section.settings.layout }}';
    const grid = document.getElementById('aCollectionGrid');

    if (layout === 'slider') {
      grid.classList.add('a-slider-mode');
    }
  </script>
</section>

{% schema %}
{
  "name": "A Feature Collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "OUR"
    },
    {
      "type": "text",
      "id": "highlight",
      "label": "Highlight Text",
      "default": "FRAGRANCES"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show View Button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "grid",
      "options": [
        {
          "value": "grid",
          "label": "Grid"
        },
        {
          "value": "slider",
          "label": "Slider"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Collection Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Perfume"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Luxury fragrance"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Collection Link"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "A Feature Collection",
      "blocks": [
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" }
      ]
    }
  ]
}
{% endschema %}
