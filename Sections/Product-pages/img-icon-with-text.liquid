{% liquid
  assign note1_img = product.metafields.custom.note_1_image
  assign note1_title = product.metafields.custom.note_1_title
  assign note1_text = product.metafields.custom.note_1_text

  assign note2_img = product.metafields.custom.note_2_image
  assign note2_title = product.metafields.custom.note_2_title
  assign note2_text = product.metafields.custom.note_2_text

  assign note3_img = product.metafields.custom.note_3_image
  assign note3_title = product.metafields.custom.note_3_title
  assign note3_text = product.metafields.custom.note_3_text

  comment
    Dynamic Color System (No Extra Metafields)
    Use product tags:
    fn-bg:#000000
    fn-title:#ffffff
    fn-text:#dddddd
  endcomment

  assign dynamic_bg = ''
  assign dynamic_title = ''
  assign dynamic_text = ''

  for tag in product.tags
    if tag contains 'fn-bg:'
      assign dynamic_bg = tag | remove: 'fn-bg:'
    elsif tag contains 'fn-title:'
      assign dynamic_title = tag | remove: 'fn-title:'
    elsif tag contains 'fn-text:'
      assign dynamic_text = tag | remove: 'fn-text:'
    endif
  endfor

  assign final_bg = dynamic_bg | default: section.settings.bg_color
  assign final_title = dynamic_title | default: section.settings.title_color
  assign final_text = dynamic_text | default: section.settings.text_color
%}

{% if note1_img != blank or note2_img != blank or note3_img != blank %}
  <section
    class="fragrance-notes border-top"
    data-notes-slider
    style="
      --bg: {{ final_bg }};
      --title-color: {{ final_title }};
      --text-color: {{ final_text }};
      --icon-size: {{ section.settings.icon_size }}px;
      --title-size: {{ section.settings.title_size }}px;
      --text-size: {{ section.settings.text_size }}px;
      --gap: {{ section.settings.gap }}px;
      --pad-y: {{ section.settings.padding_y }}px;
      --pad-x: {{ section.settings.padding_x }}px;
    "
  >
    <div class="notes-container">
      <div class="notes-track" data-track>
        {% for i in (1..3) %}
          {% if i == 1 %}
            {% assign img = note1_img %}
            {% assign title = note1_title %}
            {% assign text = note1_text %}
          {% elsif i == 2 %}
            {% assign img = note2_img %}
            {% assign title = note2_title %}
            {% assign text = note2_text %}
          {% elsif i == 3 %}
            {% assign img = note3_img %}
            {% assign title = note3_title %}
            {% assign text = note3_text %}
          {% endif %}

          {% if img != blank %}
            <div class="note-card" data-slide>
              <img
                src="{{ img | image_url: width: 400 }}"
                width="400"
                height="400"
                class="note-icon"
                loading="lazy"
                alt="{{ title | default: 'Fragrance note' | escape }}"
              >

              {% if title != blank %}
                <h3 class="note-title">{{ title }}</h3>
              {% endif %}

              {% if text != blank %}
                <p class="note-text">{{ text }}</p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="notes-dots" data-dots aria-label="Fragrance notes navigation"></div>
    </div>
  </section>
{% endif %}

<style>
  .border-top {
    border-top: 1px solid #62626257;
  }
  .fragrance-notes {
    background: var(--bg);
    padding: var(--pad-y) var(--pad-x);
  }

  .notes-container {
    max-width: 1800px;
    margin: 0 auto;
    overflow: hidden;
  }

  .notes-track {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: var(--gap);
  }

  .note-card {
    flex: 1 1 0;
    max-width: 320px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .note-icon {
    width: var(--icon-size);
    height: var(--icon-size);
    object-fit: contain;
    margin-bottom: 20px;
  }

  .note-title {
    color: var(--title-color);
    font-size: var(--title-size);
    font-weight: 500;
    font-family: 'Bebas Neue', sans-serif;
    margin-bottom: 12px;
  }

  .note-text {
    color: var(--text-color);
    font-size: var(--text-size);
    line-height: 1.6;
    max-width: 260px;
  }

  .notes-dots {
    display: none;
    justify-content: center;
    gap: 8px;
    margin-top: 30px;
  }

  .notes-dots button {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: #777;
    cursor: pointer;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .notes-dots button.active {
    background: #fff;
    transform: scale(1.3);
  }

  @media (max-width: 768px) {
    .notes-track {
      justify-content: flex-start;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 20px;
      padding-bottom: 20px;
      -webkit-overflow-scrolling: touch;
    }

    .notes-track::-webkit-scrollbar {
      height: 5px;
    }

    .notes-track::-webkit-scrollbar-thumb {
      background: #888;
      border-radius: 10px;
    }

    .notes-track {
      scrollbar-width: thin;
    }

    .note-card {
      flex: 0 0 80%;
      max-width: 80%;
      scroll-snap-align: center;
    }

    .notes-dots {
      display: flex;
    }
  }
</style>

<script>
  (function () {
    function initNotesSlider(section) {
      if (!section || window.innerWidth > 768) return;

      const track = section.querySelector('[data-track]');
      const dotsWrap = section.querySelector('[data-dots]');
      const slides = section.querySelectorAll('[data-slide]');

      if (!track || !dotsWrap || slides.length < 2) return;

      dotsWrap.innerHTML = '';

      slides.forEach((slide, i) => {
        const btn = document.createElement('button');
        btn.setAttribute('aria-label', 'Go to slide ' + (i + 1));
        if (i === 0) btn.classList.add('active');

        btn.addEventListener('click', () => {
          const offset = slide.offsetLeft - (track.clientWidth / 2 - slide.clientWidth / 2);
          track.scrollTo({
            left: offset,
            behavior: 'smooth',
          });
        });

        dotsWrap.appendChild(btn);
      });

      const dots = dotsWrap.querySelectorAll('button');

      function updateDots() {
        let index = 0;
        let minDiff = Infinity;

        slides.forEach((slide, i) => {
          const centerOffset = slide.offsetLeft - (track.clientWidth / 2 - slide.clientWidth / 2);
          const diff = Math.abs(centerOffset - track.scrollLeft);

          if (diff < minDiff) {
            minDiff = diff;
            index = i;
          }
        });

        dots.forEach((dot) => dot.classList.remove('active'));
        if (dots[index]) dots[index].classList.add('active');
      }

      let ticking = false;
      track.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(() => {
            updateDots();
            ticking = false;
          });
          ticking = true;
        }
      });
    }

    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('[data-notes-slider]').forEach(initNotesSlider);
    });

    document.addEventListener('shopify:section:load', (event) => {
      const section = event.target.querySelector('[data-notes-slider]');
      if (section) initNotesSlider(section);
    });
  })();
</script>

{% schema %}
{
  "name": "Fragrance Notes",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fallback Background color",
      "default": "#6b3a17"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Fallback Title color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Fallback Text color",
      "default": "#f0e6dc"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 60,
      "max": 200,
      "step": 10,
      "default": 120
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title font size",
      "min": 16,
      "max": 40,
      "step": 1,
      "default": 24
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between cards",
      "min": 10,
      "max": 150,
      "step": 5,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 20,
      "max": 160,
      "step": 10,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Horizontal padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Fragrance Notes",
      "category": "Product"
    }
  ]
}
{% endschema %}
