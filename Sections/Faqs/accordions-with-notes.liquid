    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    text-align: center;
  }

  /* TABLET: 2 COLUMN */
  @media (max-width: 768px) {
    .notes-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  /* MOBILE: COMPACT 3 COLUMN */
