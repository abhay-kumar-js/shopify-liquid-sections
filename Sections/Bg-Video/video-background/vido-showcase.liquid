{% comment %}
  {% liquid
    assign desktop_video = blank
    assign mobile_video = blank

    for media in product.media
      if media.media_type == 'video' or media.media_type == 'external_video'
        comment
          Naming Convention (VERY IMPORTANT):
          Upload videos with names:
          - product-desktop.mp4
          - product-mobile.mp4
        endcomment

        if media.alt contains 'mobile'
          assign mobile_video = media
        elsif media.alt contains 'desktop'
          assign desktop_video = media
        elsif desktop_video == blank
          assign desktop_video = media
        endif
      endif
    endfor
  %}

  {% if section.settings.show_section %}
    <section
      class="product-video-showcase"
      style="
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
        background: {{ section.settings.background_color }};
      "
    >
      <div class="video-container {% if section.settings.full_width %}full-width{% endif %}">
        {% if desktop_video != blank %}
          <div class="video-wrapper video-fit-{{ section.settings.video_fit }}">
            <video
              {% if section.settings.autoplay %}
                autoplay
              {% endif %}
              {% if section.settings.muted %}
                muted
              {% endif %}
              {% if section.settings.loop %}
                loop
              {% endif %}
              playsinline
              preload="none"
            >
              {% if mobile_video != blank %}
                <source
                  src="{{ mobile_video.sources[0].url }}"
                  media="(max-width: 768px)"
                >
              {% endif %}

              <source src="{{ desktop_video.sources[0].url }}" media="(min-width: 769px)">
            </video>
          </div>
        {% endif %}

        {% if section.settings.show_overlay %}
          <div
            class="video-overlay"
            style="
              background: {{ section.settings.overlay_color }};
              opacity: {{ section.settings.overlay_opacity }};
            "
          ></div>
        {% endif %}

        {% if section.settings.show_text %}
          <div
            class="video-content"
            style="text-align: {{ section.settings.text_alignment }};"
          >
            {% if section.settings.heading != blank %}
              <h2>{{ section.settings.heading }}</h2>
            {% endif %}
            {% if section.settings.subheading != blank %}
              <p>{{ section.settings.subheading }}</p>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </section>
  {% endif %}

  <style>
      .product-video-showcase {
        width: 100%;
        position: relative;
        overflow: hidden;
      }

      .video-container {
        position: relative;
        max-width: 1200px;
        margin: 0 auto;
      }

      .video-container.full-width {
        max-width: 100%;
      }



      .video-wrapper {
      position: relative;
      width: 100%;
      height: {{section.settings.video_height}}px; /* Base height - REQUIRED for object-fit */
      overflow: hidden;
    }

    .video-wrapper video {
      width: 100%;
      height: 100%;
      display: block;
    }

    /* ===== ADAPT TO WIDTH (Cinematic Cover) ===== */
    .video-fit-cover video {
      object-fit: cover;
      object-position: center;
    }

    /* ===== ADAPT TO HEIGHT (Full Video Visible) ===== */
    .video-fit-contain video {
      object-fit: contain;
      object-position: center;
      background: #000; /* prevents ugly empty space */
    }


      .video-overlay {
        position: absolute;
        inset: 0;
        pointer-events: none;
      }

      .video-content {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 2rem;
        color: {{ section.settings.text_color }};
        z-index: 2;
      }

      .video-placeholder {
        padding: 4rem;
        text-align: center;
        font-size: 1.6rem;
        opacity: 0.7;
      }
  </style>

  {% schema %}
  {
    "name": "Product Video Showcase",
    "tag": "section",
    "class": "product-video-showcase",
    "settings": [
      { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
      { "type": "checkbox", "id": "full_width", "label": "Full width", "default": true },

      { "type": "checkbox", "id": "autoplay", "label": "Autoplay video", "default": true },
      { "type": "checkbox", "id": "muted", "label": "Mute video", "default": true },
      { "type": "checkbox", "id": "loop", "label": "Loop video", "default": true },
      { "type": "checkbox", "id": "controls", "label": "Show controls", "default": false },

      {
        "type": "select",
        "id": "preload",
        "label": "Preload behavior",
        "default": "metadata",
        "options": [
          { "value": "none", "label": "None" },
          { "value": "metadata", "label": "Metadata" },
          { "value": "auto", "label": "Auto" }
        ]
      },

      { "type": "image_picker", "id": "poster_image", "label": "Poster image (fallback)" },

      { "type": "checkbox", "id": "show_overlay", "label": "Show overlay", "default": false },
      { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#000000" },
      {
        "type": "range",
        "id": "overlay_opacity",
        "label": "Overlay opacity",
        "min": 0,
        "max": 1,
        "step": 0.1,
        "default": 0.4
      },

      { "type": "checkbox", "id": "show_text", "label": "Show text overlay", "default": false },
      { "type": "text", "id": "heading", "label": "Heading" },
      { "type": "textarea", "id": "subheading", "label": "Subheading" },
      {
        "type": "select",
        "id": "text_alignment",
        "label": "Text alignment",
        "default": "center",
        "options": [
          { "value": "left", "label": "Left" },
          { "value": "center", "label": "Center" },
          { "value": "right", "label": "Right" }
        ]
      },
      { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },

      { "type": "color", "id": "background_color", "label": "Section background color", "default": "transparent" },
      {
        "type": "range",
        "id": "border_radius",
        "label": "Video border radius",
        "min": 0,
        "max": 40,
        "step": 2,
        "default": 0
      },

      { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "default": 40 },
      {
        "type": "range",
        "id": "padding_bottom",
        "label": "Padding bottom",
        "min": 0,
        "max": 120,
        "step": 4,
        "default": 40
      },

      { "type": "checkbox", "id": "show_placeholder", "label": "Show placeholder if no video", "default": true },
      {
        "type": "text",
        "id": "placeholder_text",
        "label": "Placeholder text",
        "default": "Upload a product video to display here."
      },
      {
        "type": "select",
        "id": "video_fit",
        "label": "Video Adapt Mode",
        "default": "cover",
        "options": [
          {
            "value": "cover",
            "label": "Adapt to Width (Cover)"
          },
          {
            "value": "contain",
            "label": "Adapt to Height (Contain)"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Product Video Showcase",
        "category": "Product"
      }
    ]
  }
  {% endschema %}
{% endcomment %}

{% comment %}
  -----------------------
   second final
   -------------------
{% endcomment %}
{% liquid
  assign product_video = blank

  for media in product.media
    if media.media_type == 'video' or media.media_type == 'external_video'
      assign product_video = media
      break
    endif
  endfor
%}

{% if section.settings.show_section %}
  <section
    class="product-video-showcase"
    style="
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      background: {{ section.settings.background_color }};
    "
  >
    {% if product_video != blank %}
      <div class="video-wrapper">
        {% if product_video.media_type == 'video' %}
          {{
            product_video
            | video_tag:
              autoplay: section.settings.autoplay,
              loop: section.settings.loop,
              muted: true,
              controls: false,
              playsinline: true
          }}
        {% else %}
          {{ product_video | external_video_tag }}
        {% endif %}
      </div>
    {% elsif section.settings.show_placeholder %}
      <div class="video-placeholder">
        {{ section.settings.placeholder_text }}
      </div>
    {% endif %}
  </section>
{% endif %}

<style>
  /* ✅ TRUE FULL WIDTH WITHOUT VW */
  .product-video-showcase {
    width: 100%;
    max-width: 100%;
    margin: 0;
    padding-left: 0;
    padding-right: 0;
  }

  /* ✅ BREAK OUT OF THEME CONTAINER SAFELY */
  .product-video-showcase {
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50%;
    margin-right: -50%;
    width: 100%;
  }

  /* ✅ REMOVE INLINE GAPS */
  .product-video-showcase {
    line-height: 0;
  }

  /* ✅ VIDEO WRAPPER */
  .video-wrapper {
    width: 100%;
    height: 950px;
  }

  /* ✅ FORCE PERFECT FIT */
  .video-wrapper video,
  .video-wrapper iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    border: 0;
  }

  /* ✅ SHOPIFY INTERNAL WRAPPER FIX */
  .video-wrapper > * {
    width: 100% !important;
    height: 100% !important;
  }

  /* ✅ MOBILE */
  @media (max-width: 768px) {
    .video-wrapper {
      height: {{ section.settings.mobile_video_height }}px;
    }
  }

  .video-placeholder {
    padding: 40px;
    text-align: center;
  }
</style>

{% schema %}
{
  "name": "Product Video Showcase",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "range",
      "id": "mobile_video_height",
      "label": "Mobile video height",
      "min": 200,
      "max": 800,
      "step": 10,
      "default": 500
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "transparent"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },
    {
      "type": "checkbox",
      "id": "show_placeholder",
      "label": "Show placeholder",
      "default": true
    },
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "Placeholder text",
      "default": "Upload a product video"
    }
  ],
  "presets": [
    {
      "name": "Product Video Showcase"
    }
  ]
}
{% endschema %}
