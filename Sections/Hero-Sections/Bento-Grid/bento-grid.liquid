<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bento Grid</title>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      .bento-container {
        display: grid;
        grid-template-columns: 1fr;
      }

      /* Common */
      .bento-item {
        width: 100%;
        position: relative;
        overflow: hidden;
      }

      .bento-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      /* Sections */
      .top {
        height: 340px;
      }
      .mid {
        height: 280px;
      }

      .bottom-row {
        display: flex;
        height: auto;
      }

      .col {
        position: relative;
        height: 100%;
      }

      .col.image {
        width: 40%;
      }
      .col.gif {
        width: 60%;
      }

      /* CENTERED COUPON */
      .coupon-wrapper {
        width: 50%;
        position: absolute;
        top: 60%;
        left: 50%;
        transform: translate(-50%, -50%);
      }

      /* Coupon UI */
      .coupon-box {
        text-align: center;
      }

      .offer-text {
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 6px;
      }

      .main-offer {
        font-size: 20px;
        font-weight: 800;
        margin-bottom: 10px;
      }

      .coupon-code {
        color: #fff;
        font-weight: bold;
        letter-spacing: 2px;
        border-radius: 4px;
        display: inline-block;
      }

      .coupon-main-container {
        display: flex;
        flex-direction: column;
        background: #000;
        padding-block: 1.4rem;
        padding-inline: 1.5rem;
        border-radius: 0.2rem;
        position: relative;
      }
      .copy-container {
        padding: 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border: 2px dashed #000;
        background: #fcfdff;
      }
      .couponHeading {
        font-size: 13.5px;
        line-height: 1rem;
        margin: 0;
        color: #fff;
        padding-left: 0.2rem;
        margin-bottom: 0.1rem;
      }

      #copyText {
        color: #000;
        max-width: 60%;
        width: 200px;
        font-size: 1.4rem;
        font-weight: 600;
        outline: none;
        border: none;
        background: transparent;
        padding-left: 0.5rem;
      }

      #copyBtn {
        font-size: 1.4rem;
        padding: 4px 8px;
        background-color: #1c1c1c;
        margin-right: 0.2rem;
        margin-block: 0.2rem;
        color: white;
        border: none;
        cursor: pointer;
        border-radius: 0.2rem;
      }

      #copyBtn:hover {
        background-color: #000;
      }
      .circle-1,
      .circle-2 {
        background-color: #fff;
        width: 21px;
        height: 21px;
        border-radius: 50%;
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
      }
      .circle-1 {
        left: -10.5px;
      }
      .circle-2 {
        right: -10.5px;
      }
      #img-size {
        width: 100%;
      }
      /* Responsive */
      @media (min-width: 769px) and (max-width: 1180px) {
        #img-size {
          width: 100%;
        }
        #copyText {
          font-size: 1rem;
        }

        #copyBtn {
          font-size: 1rem;
          padding: 2px 8px;
        }
        .coupon-wrapper {
          width: 66%;
        }
        .bento-item img {
          width: 100%;
          height: auto;
          object-fit: cover;
        }

        /* Sections */
        .top {
          height: auto;
        }
        .mid {
          height: auto;
        }
      }

      @media (max-width: 768px) {
        #img-size {
          width: 60%;
          margin: 0 auto;
        }
        #copyText {
          font-size: 0.85rem;
        }

        #copyBtn {
          font-size: 0.85rem;
          padding: 0px 8px;
        }
        .coupon-wrapper {
          width: 66%;
        }
        .bento-item img {
          height: auto;
        }
        .top {
          height: auto;
        }
        .mid {
          height: auto;
        }

        .bottom-row {
          flex-direction: column;
          height: auto;
        }

        .col.image,
        .col.gif {
          width: 100%;
          height: auto;
          padding-top: 1rem;
        }
        .copy-container {
          padding: 0.4rem 0;
        }
      }
    </style>
  </head>

  <body>
    <section class="bento-grid">
      <div class="bento-container">
        <!-- TOP -->
        <div class="bento-item top">
          <img width="" height="" src="https://cdn.shopify.com/s/files/1/0589/5477/6664/files/hey-you.gif?v=1774945868">
        </div>

        <!-- MID -->
        <div class="bento-item mid">
          <img
            width=""
            height=""
            src="https://cdn.shopify.com/s/files/1/0589/5477/6664/files/april-fool.gif?v=1774945868"
          >
        </div>

        <!-- BOTTOM -->
        <div class="bento-item bottom-row">
          <!-- LEFT IMAGE -->
          <div class="col image">
            <img
              id="img-size"
              width=""
              height=""
              src="https://cdn.shopify.com/s/files/1/0589/5477/6664/files/DONTWORRY.gif?v=1774957301"
            >
          </div>

          <!-- RIGHT GIF -->
          <div class="col gif">
            <img
              width=""
              height=""
              src="https://cdn.shopify.com/s/files/1/0589/5477/6664/files/FLAT30_OFF.png?v=1775199341"
            >

            <!-- CENTERED COUPON -->
            <div class="coupon-wrapper">
              <div class="coupon-main-container">
                <div class="coupon-code">
                  <div class="copy-container">
                    <input type="text" value="FLAT30%OFF" id="copyText" readonly>
                    <button onclick="copyToClipboard()" id="copyBtn">Copy</button>
                  </div>
                  <div class="circle-1"></div>
                  <div class="circle-2"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <script>
      function copyToClipboard() {
        // Get the text field
        var copyText = document.getElementById('copyText');

        // Select the text field
        copyText.select();
        copyText.setSelectionRange(0, 99999); // For mobile devices

        // Copy the text inside the text field
        document.execCommand('copy');

        // Alert the copied text (optional)
        alert('Copied: ' + copyText.value);
      }
    </script>
  </body>
</html>
