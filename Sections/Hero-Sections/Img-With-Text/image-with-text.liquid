      color:var(--title-color);
      font-size:clamp(22px,4vw,32px);
      font-weight:500;
      margin-bottom:12px;
      font-family: "Bebas Neue", sans-serif;
    }

    .fragrance-bg p{
      color:var(--text-color);
      font-size:16px;
      line-height:1.6;
      max-width:520px;
    }

      .fragrance-bg .banner-container{

        padding:
          var(--m-layout-pad-top)
          var(--m-layout-pad-right)
          var(--m-layout-pad-bottom)
          var(--m-layout-pad-left);

      }

      .fragrance-bg .banner-layout{
        flex-direction:column;
        gap:24px;
      }

      .fragrance-bg .banner-layout.is-mobile-reverse{
        flex-direction:column-reverse;
      }

      .fragrance-bg .banner-content{

        width:var(--mobile-content-width);
        max-width:var(--mobile-content-width);
        margin:0 auto;

        padding:
          var(--m-content-pad-top)
          var(--m-content-pad-right)
          var(--m-content-pad-bottom)
          var(--m-content-pad-left);

      }

      .fragrance-bg .mobile-align-left{
        text-align:left;
        align-items:flex-start;
      }

      .fragrance-bg .mobile-align-center{
        text-align:center;
        align-items:center;
      }

      .fragrance-bg .mobile-align-right{
        text-align:right;
        align-items:flex-end;
      }

    }
  </style>

